---
interface Icono {
  name?: string;
  imagen?: string;
}

interface Proyect {
  title?: string;
  description?: string;
  dia?: string;
  anio?: string;
  mes?: string;
  image?: string;
  git?: string;
  url?: string;
  skills?: Icono[];
  tipo?: string; // "back" | "front" | "fullstack"
  orientation?: string; // "portrait" | "landscape"
}

export interface Props {
  proyectos?: Array<Proyect>;
}

const { proyectos = [] } = Astro.props;

const tipoLabel = (tipo?: string) => {
  if (tipo === "front") return "front-end";
  if (tipo === "back") return "back-end";
  if (tipo === "fullstack") return "full-stack";
  return "proyecto";
};

const tipoColor = (tipo?: string) => {
  if (tipo === "front") return "bg-blue-500";
  if (tipo === "back") return "bg-principal-400";
  if (tipo === "fullstack") return "bg-emerald-600";
  return "bg-principal-400";
};
---

<section class="text-principal-600 body-font">
  <div class="container mx-auto px-6 pt-6 pb-8">
    <div class="mb-8">
      <p class="mx-auto max-w-4xl leading-relaxed text-base text-principal-700">
        Proyectos desarrollados en <b>PHP (CodeIgniter/Laravel)</b> y <b>APIs en Node.js</b>, con front-end en
        <b>Astro + Tailwind</b>. Experiencia en <b>optimización SQL</b>, <b>consolidación de datos</b> y
        <b>tiempo real con Redis + WebSockets</b>, desplegando en <b>Linux (Nginx/Apache) y Docker</b>.
      </p>
    </div>

    <div class="flex flex-col gap-6">
      {
        proyectos.map((p, index) => {
          const isOdd = (index + 1) % 2 === 1;
          const orientation = p.orientation ?? "landscape";

          return (
            <article class="border-2 border-principal-200 bg-white shadow-sm rounded-xl overflow-hidden hover:shadow-lg transition">
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
                {/* Imagen */}
                <button
                  type="button"
                  class={`relative group lg:col-span-1 w-full text-left ${
                    isOdd ? "lg:order-1" : "lg:order-3"
                  }`}
                  data-modal-src={`/imagenes/portafolio/${p.image ?? ""}`}
                  data-orientation={orientation}
                >
                  {/* Badge tipo */}
                  <span
                    class={`absolute top-3 left-3 z-10 inline-flex items-center gap-2 rounded-md px-2 py-1 text-xs font-semibold text-white ${tipoColor(p.tipo)}`}
                  >
                    <img class="w-4 h-4" src={`/imagenes/portafolio/${p.tipo ?? "back"}-end.svg`} alt="" />
                    {tipoLabel(p.tipo)}
                  </span>

                  <div
                    class={`w-full bg-principal-50 overflow-hidden flex items-center justify-center ${
                      orientation === "portrait" ? "h-[380px]" : "h-[260px] lg:min-h-[240px]"
                    }`}
                  >
                    <img
                      src={`/imagenes/portafolio/${p.image ?? ""}`}
                      alt={p.title ?? "Proyecto"}
                      class={`w-full h-full transition ${
                        orientation === "portrait"
                          ? "object-contain"
                          : "object-cover object-top"
                      }`}
                      loading="lazy"
                    />
                  </div>
                </button>

                {/* Contenido */}
                <div class={`lg:col-span-2 p-6 ${isOdd ? "lg:order-2" : "lg:order-2"}`}>
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <h3 class="text-lg md:text-xl font-bold text-principal-900 uppercase">
                      {p.title}
                    </h3>

                    {(p.mes || p.anio) && (
                      <span class="text-sm text-principal-500">
                        {p.mes ? `${p.mes} ` : ""}{p.anio ?? ""}
                      </span>
                    )}
                  </div>

                  {p.description && (
                    <p class="mt-3 text-principal-700 leading-relaxed">
                      {p.description}
                    </p>
                  )}

                  {/* Skills */}
                  <div class="mt-4 flex flex-wrap gap-2">
                    {(p.skills ?? []).map((s) => (
                      <span class="inline-flex items-center gap-2 rounded-full bg-purple-50 px-3 py-1 text-xs text-purple-700 border border-purple-100">
                        <img
                          class="w-4 h-4"
                          src={`/imagenes/portafolio/${s.imagen}.svg`}
                          alt={s.name ?? "skill"}
                          loading="lazy"
                          onerror="this.style.display='none'"
                        />
                        <span class="font-medium">{s.name}</span>
                      </span>
                    ))}
                  </div>

                  {/* Links */}
                  <div class="mt-5 flex flex-wrap items-center gap-3">
                    {p.git && (
                      <a
                        href={p.git}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded-lg border border-principal-200 px-3 py-2 text-sm text-principal-800 hover:bg-principal-50 transition"
                        aria-label="Abrir repositorio GitHub"
                      >
                        <img class="w-5 h-5" src="/imagenes/portafolio/github.svg" alt="GitHub" />
                        GitHub
                      </a>
                    )}

                    {p.url && (
                      <a
                        href={p.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded-lg border border-principal-200 px-3 py-2 text-sm text-principal-800 hover:bg-principal-50 transition"
                        aria-label="Abrir demo / URL"
                      >
                        <img class="w-5 h-5" src="/imagenes/portafolio/url.svg" alt="URL" />
                        Ver demo
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>

  {/* Modal FULL SCREEN */}
  <div id="modal" class="fixed inset-0 hidden z-[999] bg-black">
    <button
      class="absolute top-4 right-4 z-10 text-white text-3xl closeModal"
      aria-label="Cerrar"
      type="button"
    >
      ✕
    </button>

    <div class="w-screen h-screen flex items-center justify-center">
      <img
        id="modal-img"
        src=""
        alt="Preview"
        class="max-w-screen max-h-screen object-contain"
      />
    </div>
  </div>
</section>

<script>
  const modal = document.getElementById("modal");
  const modalImg = document.getElementById("modal-img");

  // abrir modal
  document.addEventListener("click", (e) => {
    const btn = e.target.closest("button[data-modal-src]");
    if (!btn) return;

    const src = btn.getAttribute("data-modal-src");
    if (!src) return;

    modalImg.src = src;
    modal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  });

  // cerrar modal
  const closeModal = () => {
    modal.classList.add("hidden");
    modalImg.src = "";
    document.body.style.overflow = "";
  };

  document.querySelectorAll(".closeModal").forEach((el) =>
    el.addEventListener("click", closeModal)
  );

  // cerrar tocando fondo negro
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  // cerrar con ESC
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });
</script>
